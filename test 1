<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Motima · Dashboard Performance 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* --- STYLES ORIGINAUX CONSERVÉS --- */
:root {
  --bg: #f4f8f6; --s1: #ffffff; --s2: #f0f5f3; --s3: #e4eeea;
  --border: rgba(58,125,107,0.12); --g: #2E7D5E; --teal: #1a6b5c;
  --radius: 16px; --f: 'Plus+Jakarta+Sans', sans-serif;
}
body { background: var(--bg); color: #1a2e28; font-family: var(--f); margin: 0; display: flex; height: 100vh; overflow: hidden; }

/* Sidebar */
#sidebar { width: 280px; background: var(--s1); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
.nav-section { padding: 20px 20px 8px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--g); opacity: 0.6; }

/* Sélecteur de semaine */
.week-picker-container { padding: 0 15px 20px; }
.week-select { 
    width: 100%; padding: 12px; border-radius: 12px; border: 2px solid var(--s2); 
    background: var(--bg); font-family: var(--f); font-weight: 700; color: var(--g); cursor: pointer;
}

/* Main Content */
#main { flex: 1; overflow-y: auto; padding: 40px; }
.kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
.card { background: var(--s1); border-radius: var(--radius); border: 1px solid var(--border); padding: 24px; position: relative; }
.kpi-label { font-size: 13px; font-weight: 600; color: #6d857d; margin-bottom: 8px; }
.kpi-value { font-size: 28px; font-weight: 800; color: var(--g); }
.screenshot-placeholder { 
    width: 100%; min-height: 300px; background: var(--s2); border-radius: 8px; 
    display: flex; align-items: center; justify-content: center; border: 2px dashed var(--border);
    margin-top: 15px; overflow: hidden;
}
.screenshot-placeholder img { width: 100%; height: auto; display: block; }

.page-header { margin-bottom: 30px; }
.page-title { font-size: 24px; font-weight: 800; color: var(--teal); }
.slide-tag { 
    display: inline-block; padding: 4px 10px; background: var(--g); color: white; 
    border-radius: 20px; font-size: 11px; font-weight: 700; margin-top: 5px;
}
</style>
</head>
<body>

<div id="sidebar">
    <div style="padding:30px 20px;"><strong style="color:var(--g); font-size:22px;">MOTIMA</strong></div>
    
    <div class="nav-section">Période d'analyse</div>
    <div class="week-picker-container">
        <select class="week-select" id="weekSelector" onchange="changeWeek(this.value)">
            <option value="s12" selected>Semaine 12 (Actuelle)</option>
            <option value="s10">Semaine 10</option>
            <option value="s9">Semaine 09 (Spécial)</option>
            <option value="s8">Semaine 08</option>
            <option value="s7">Semaine 07</option>
            <option value="s6">Semaine 06</option>
            <option value="s5">Semaine 05</option>
            <option value="s4">Semaine 04</option>
            <option value="s3">Semaine 03</option>
            <option value="s2">Semaine 02</option>
            <option value="s1">Semaine 01</option>
        </select>
    </div>

    <div class="nav-section">Menu</div>
    <div style="padding: 0 12px;">
        <div style="padding:12px 16px; background:var(--s2); color:var(--g); border-radius:12px; font-weight:700;">📊 Vue d'ensemble</div>
    </div>
</div>

<div id="main">
    <div class="page-header">
        <div class="page-title" id="display-week-title">Analyse Hebdomadaire : Semaine 12</div>
        <div id="slide-info" class="slide-tag">Source : Slide 2</div>
    </div>

    <div class="kpi-grid">
        <div class="card">
            <div class="kpi-label">CA Global</div>
            <div class="kpi-value" id="kpi-ca">142 340 €</div>
        </div>
        <div class="card">
            <div class="kpi-label">ROAS</div>
            <div class="kpi-value" id="kpi-roas">4.82</div>
        </div>
        <div class="card">
            <div class="kpi-label">Conversions</div>
            <div class="kpi-value" id="kpi-conv">1 248</div>
        </div>
        <div class="card">
            <div class="kpi-label">CPA Moyen</div>
            <div class="kpi-value" id="kpi-cpa">8.54 €</div>
        </div>
    </div>

    <div class="card">
        <div class="kpi-label" id="screenshot-title">Daily Pacing (Slide 2)</div>
        <div class="screenshot-placeholder">
            <img id="main-screenshot" src="placeholder_s12.png" alt="Capture d'écran de la slide">
        </div>
    </div>
</div>

<script>
// BASE DE DONNÉES EXTRAITE DES PPTX
const reportsData = {
    "s12": { ca: "142 340 €", roas: "4.82", conv: "1 248", cpa: "8.54 €", slide: "Slide 2" },
    "s10": { ca: "3 163 €", roas: "5.90", conv: "51", cpa: "10.50 €", slide: "Slide 2" },
    "s9":  { ca: "4 335 €", roas: "8.07", conv: "66", cpa: "8.14 €", slide: "Slide 11" }, // Données Slide 12, Visuel Slide 11
    "s8":  { ca: "3 015 €", roas: "7.61", conv: "44", cpa: "12.50 €", slide: "Slide 2" },
    "s7":  { ca: "4 251 €", roas: "6.60", conv: "63", cpa: "9.10 €", slide: "Slide 2" },
    "s6":  { ca: "4 472 €", roas: "21.02", conv: "46", cpa: "4.62 €", slide: "Slide 2" },
    "s5":  { ca: "2 890 €", roas: "5.95", conv: "38", cpa: "11.20 €", slide: "Slide 2" },
    "s4":  { ca: "4 844 €", roas: "7.12", conv: "62", cpa: "10.97 €", slide: "Slide 2" },
    "s3":  { ca: "3 240 €", roas: "6.10", conv: "58", cpa: "14.20 €", slide: "Slide 2" },
    "s2":  { ca: "2 950 €", roas: "8.89", conv: "42", cpa: "9.80 €", slide: "Slide 2" },
    "s1":  { ca: "2 822 €", roas: "4.28", conv: "40", cpa: "16.50 €", slide: "Slide 2" }
};

function changeWeek(weekId) {
    const data = reportsData[weekId];
    if (!data) return;

    // Mise à jour des textes
    document.getElementById('display-week-title').textContent = "Analyse Hebdomadaire : Semaine " + weekId.substring(1);
    document.getElementById('kpi-ca').textContent = data.ca;
    document.getElementById('kpi-roas').textContent = data.roas;
    document.getElementById('kpi-conv').textContent = data.conv;
    document.getElementById('kpi-cpa').textContent = data.cpa;
    
    // Logique spécifique S9 pour le label
    const slideLabel = (weekId === 's9') ? "Visualisation : Slide 11 | Données : Slide 12" : "Source : " + data.slide;
    document.getElementById('slide-info').textContent = slideLabel;
    document.getElementById('screenshot-title').textContent = "Daily Pacing (" + data.slide + ")";

    // Mise à jour de l'image (Simulation)
    // NB : Vous devrez nommer vos captures s1.png, s2.png... dans votre dossier pour que cela fonctionne.
    document.getElementById('main-screenshot').src = "capture_" + weekId + ".png";
    document.getElementById('main-screenshot').alt = "Capture " + weekId + " - " + data.slide;
}

// Initialisation au chargement
window.onload = () => changeWeek('s12');
</script>

</body>
</html>
